<mujoco model="double_pendulum">
    <!-- compiler 配置：角度使用度数(degree)，使用局部坐标系(coordinate="local") -->
    <compiler coordinate="local" angle="degree"/>
    
    <!-- option 配置：设置重力加速度和仿真步长 -->
    <option gravity="0 0 -9.81" timestep="0.002"/>

    <asset>
        <!-- 定义纹理与材质，使仿真画面看起来更真实高级 -->
        <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="512" height="512"/>
        <material name="grid_material" texture="grid" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <!-- 灰色网格地板，充当背景 -->
        <geom name="floor" type="plane" size="5 5 0.1" material="grid_material"/>
        
        <!-- 光源配置，照亮整个场景 -->
        <light diffuse=".8 .8 .8" pos="0 0 4" dir="0 0 -1"/>

        <!-- 双摆的固定底座支架，无joint定义，因此默认固定在世界坐标系中 (z = 2 米高处) -->
        <body name="stand" pos="0 0 2">
            <geom name="stand_geom" type="cylinder" size="0.05 0.1" rgba="0.5 0.5 0.5 1"/>
            
            <!-- 第一级摆杆 (link1)：父级为 stand。pos="0 0 0" 意为其坐标系原点与 stand 重合 -->
            <body name="link1" pos="0 0 0">
                <!-- 铰链关节：绕 Y 轴转动。axis="0 1 0" 表示旋转轴为 Y 轴 -->
                <!-- damping: 阻尼系数，用来模拟空气阻力或关节摩擦阻力 -->
                <!-- frictionloss: 库伦干摩擦力矩，用于防止小幅摆动时永不停歇 -->
                <joint name="joint1" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.1" frictionloss="0.02"/>
                
                <!-- 摆杆胶囊体：从自身的 (0,0,0) 延伸至 (0,0,-0.5) 米，半径为 0.03 米 -->
                <!-- 通过 mass 设定质量，MuJoCo 会自动根据几何体形状计算其惯性张量 -->
                <geom name="link1_geom" type="capsule" fromto="0 0 0  0 0 -0.5" size="0.03" rgba="0.8 0.2 0.2 1" mass="1.0"/>
                
                <!-- 第二级摆杆 (link2)：父级为 link1。pos="0 0 -0.5" 意为其坐标原点设在第一级摆杆的底端 -->
                <body name="link2" pos="0 0 -0.5">
                    <!-- 铰链关节：同样绕 Y 轴转动，阻尼略小 -->
                    <joint name="joint2" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.05" frictionloss="0.01"/>
                    
                    <!-- 第二摆杆胶囊体：从自身的 (0,0,0) 延伸至 (0,0,-0.5) 米，半径为 0.025 米 -->
                    <geom name="link2_geom" type="capsule" fromto="0 0 0  0 0 -0.5" size="0.025" rgba="0.2 0.2 0.8 1" mass="0.8"/>
                </body>
            </body>
        </body>
    </worldbody>
</mujoco>
